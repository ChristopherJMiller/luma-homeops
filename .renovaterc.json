{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":prHourlyLimitNone",
    ":prConcurrentLimitNone",
    ":pinVersions",
    "docker:pinDigests",
    ":rebaseStalePrs",
    ":automergeMinor",
    ":automergeDigest",
    ":skipStatusChecks",
    "group:allNonMajor"
  ],
  "kubernetes": {
    "fileMatch": ["cluster/.+\\.yaml$"]
  },
  "packageRules": [
    {
      "matchPackageNames": [
        "ghcr.io/christopherjmiller/ceph-nfs-export-operator"
      ],
      "groupName": "ceph-nfs-export-operator",
      "schedule": ["at any time"]
    }
  ]
}
